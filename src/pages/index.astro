		box-shadow: 0 0 8px var(--accent-shadow);
	}

	.pw-submit:hover {
		background: var(--accent-0);
		box-shadow: 0 0 14px var(--accent-shadow-strong);
	}

	/* ─── Footer ─── */
	.site-footer {
		margin-top: 4rem;
	}

	/* Animated blue dashed line from blog */
	.footer-line {
		position: relative;
		overflow: hidden;
		height: 6px;
		margin-bottom: 1rem;
		opacity: 0.4;
		transition: opacity 0.3s;
	}

	.footer-line::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 200%;
		height: 100%;
		background: linear-gradient(to left, var(--accent) 50%, transparent 0%) repeat-x 0 0 / 100px 6px;
		animation: slide-line 3s linear infinite;
		filter: drop-shadow(0 0 2px var(--accent));
	}

	.site-footer:hover .footer-line {
		opacity: 0.7;
	}

	@keyframes slide-line {
		100% {
			transform: translateX(-100px);
		}
	}

	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
		font-size: 0.8rem;
		color: var(--text-faint);
	}

	.footer-copy a,
	.footer-links a {
		color: var(--accent);
		border-bottom: 1px solid transparent;
		transition: border-color 0.15s;
	}

	.footer-copy a:hover,
	.footer-links a:hover {
		border-color: var(--accent);
	}

	.footer-links {
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}

	/* ─── Responsive ─── */
	@media (max-width: 640px) {
		.slides-grid {
			grid-template-columns: 1fr;
		}
		.title-zh {
			font-size: 2rem;
		}
		.header-meta {
			flex-wrap: wrap;
		}
		.stats-row {
			width: 100%;
			justify-content: space-between;
		}
	}
</style>
