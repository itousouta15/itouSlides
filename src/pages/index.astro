		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.pw-label {
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--text-muted);
		letter-spacing: 0.04em;
	}

	.pw-input {
