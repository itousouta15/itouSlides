---
export interface SlideData {
	title: string;
	subtitle: string | null;
	description: string;
	tags: string[];
	year: number;
	hosted: boolean;
	url: string;
}

interface Props {
	slide: SlideData;
	index: number;
}

const { slide, index } = Astro.props;
const { url } = slide;

function getLinkType(url: string): "hosted" | "drive" | "sitcon" | "github" | "external" {
	if (url.startsWith("/talks/")) return "hosted";
	if (url.includes("drive.google.com")) return "drive";
	if (url.includes("sitcon.org")) return "sitcon";
	if (url.includes("github.com")) return "github";
	return "external";
}

const linkType = getLinkType(url);
const isExternal = linkType !== "hosted";

const linkLabels: Record<string, string> = {
	hosted: "開啟簡報",
	drive: "Google Drive",
	sitcon: "SITCON 議程",
	github: "GitHub",
	external: "前往查看"
};
const linkLabel = linkLabels[linkType];

const tagLabels: Record<string, string> = {
	security: "資訊安全",
	web: "網頁開發",
	software: "軟體開發",
	design: "設計",
	oss: "開源社群",
	AI: "人工智慧"
};
---

<article class="slide-card" data-tags={slide.tags.join(",")} style={`animation-delay: ${index * 60}ms`}>
	<header class="card-header">
		<span class="card-index mono">#{String(index + 1).padStart(2, "0")}</span>
		<div class="card-tags">
			{slide.tags.map((tag: string) => <span class={`card-tag tag-${tag}`}>{tagLabels[tag] ?? tag}</span>)}
		</div>
	</header>

	<div class="card-body">
		<h3 class="card-title">{slide.title}</h3>
		{slide.subtitle && <p class="card-subtitle">{slide.subtitle}</p>}
		<p class="card-description">{slide.description}</p>
	</div>

	<footer class="card-footer">
		<span class="card-year mono">{slide.year}</span>
		<a href={url} class="card-link" target="_blank" rel={isExternal ? "noopener" : undefined}>
			{linkLabel}
			<span class="link-arrow" aria-hidden="true">→</span>
		</a>
	</footer>
</article>

<style>
	.slide-card {
		position: relative;
		background: var(--surface);
		border: 1.5px solid var(--border);
		border-radius: var(--radius);
		padding: 1.5rem;
		transition:
			transform 0.2s,
			box-shadow 0.2s,
			border-color 0.2s;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		opacity: 0;
		animation: card-in 0.3s ease forwards;
		box-shadow: 0 0 10px 2px var(--hover-shadow);
	}

	@keyframes card-in {
		from {
			opacity: 0;
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.slide-card:hover {
		transform: scale(1.01) translateY(-2px);
		box-shadow: 0 0 18px 4px var(--hover-shadow);
		border-color: var(--accent-3);
	}

	/* ─── Header ─── */
	.card-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.card-index {
		font-size: 0.75rem;
		color: var(--text-faint);
		letter-spacing: 0.05em;
		flex-shrink: 0;
	}

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.3rem;
		justify-content: flex-end;
	}

	.card-tag {
		font-size: 0.72rem;
		letter-spacing: 0.06em;
		font-weight: 700;
		padding: 0.2rem 0.65rem;
		border-radius: 10px;
		border: 1px solid var(--border);
		color: var(--text-muted);
		background: var(--accent-6);
		text-transform: uppercase;
	}

	/* Tag colors — light mode */
	.tag-security {
		border-color: #ab8f13d7;
		color: #a09519;
		background: #8a7c4326;
	}
	.tag-web {
		border-color: #7b9e87;
		color: #3a6146;
		background: #edf5f0;
	}
	.tag-software {
		border-color: #6b82b5;
		color: #2d4a82;
		background: #edf1f9;
	}
	.tag-design {
		border-color: #b58a6b;
		color: #7a4520;
		background: #f9f1ed;
	}
	.tag-oss {
		border-color: #9b7eb5;
		color: #4e2a80;
		background: #f4f0f9;
	}
	.tag-AI {
		border-color: #5ba8b5;
		color: #1a5a6b;
		background: #edf7f9;
	}

	/* Tag colors — dark mode */
	:global([data-theme="dark"]) .tag-web {
		border-color: #4a6e54;
		color: #7bc893;
		background: rgba(60, 100, 72, 0.2);
	}
	:global([data-theme="dark"]) .tag-software {
		border-color: #3d5285;
		color: #7da4e8;
		background: rgba(45, 74, 130, 0.2);
	}
	:global([data-theme="dark"]) .tag-design {
		border-color: #7a5340;
		color: #d4956a;
		background: rgba(122, 69, 32, 0.2);
	}
	:global([data-theme="dark"]) .tag-oss {
		border-color: #5e3d7a;
		color: #b590e8;
		background: rgba(78, 42, 128, 0.2);
	}
	:global([data-theme="dark"]) .tag-AI {
		border-color: #2d6b7a;
		color: #6ac9d8;
		background: rgba(26, 90, 107, 0.2);
	}

	/* ─── Body ─── */
	.card-body {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.card-title {
		font-size: 1.15rem;
		font-weight: 700;
		line-height: 1.3;
		color: var(--text);
		letter-spacing: -0.01em;
	}

	.card-subtitle {
		font-size: 0.8rem;
		color: var(--text-muted);
		font-style: italic;
	}

	.card-description {
		font-size: 0.9rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin-top: 0.25rem;
	}

	/* ─── Footer ─── */
	.card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-top: 1px solid var(--border);
		padding-top: 0.75rem;
		margin-top: auto;
	}

	.card-year {
		font-size: 0.75rem;
		color: var(--text-faint);
	}

	.card-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: var(--accent);
		padding: 0.35rem 0.9rem;
		border: 1.5px solid var(--accent);
		border-radius: 10px;
		background: var(--accent-6);
		transition:
			background 0.15s,
			color 0.15s,
			box-shadow 0.15s;
		box-shadow: 0 0 5px 1px var(--accent-shadow);
	}

	.card-link:hover {
		background: var(--accent);
		color: #fff;
		box-shadow: 0 0 10px var(--accent-shadow-strong);
	}

	.link-arrow {
		transition: transform 0.15s;
	}

	.card-link:hover .link-arrow {
		transform: translateX(3px);
	}
</style>
