---
export interface HomeworkData {
	title: string;
	subject: string;
	description: string;
	year: number;
	url: string;
}

interface Props {
	hw: HomeworkData;
	index: number;
}

const { hw, index } = Astro.props;
const isExternal = hw.url.startsWith("http");
---

<article class="hw-card" style={`animation-delay: ${index * 60}ms`}>
	<header class="hw-header">
		<span class="hw-index mono">#{String(index + 1).padStart(2, "0")}</span>
		<span class="hw-subject">{hw.subject}</span>
	</header>

	<div class="hw-body">
		<h3 class="hw-title">{hw.title}</h3>
		<p class="hw-desc">{hw.description}</p>
	</div>

	<footer class="hw-footer">
		<span class="hw-year mono">{hw.year}</span>
		<a
			href={hw.url !== "#" ? hw.url : undefined}
			class={`hw-link${hw.url === "#" ? " hw-link-disabled" : ""}`}
			target={hw.url !== "#" ? "_blank" : undefined}
			rel={isExternal ? "noopener" : undefined}
		>
			開啟檔案
			<span class="link-arrow" aria-hidden="true">→</span>
		</a>
	</footer>
</article>

<style>
	.hw-card {
		background: var(--surface);
		border: 1.5px solid var(--border);
		border-radius: var(--radius);
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		opacity: 0;
		animation: card-in 0.3s ease forwards;
		transition:
			transform 0.2s,
			box-shadow 0.2s,
			border-color 0.2s;
		box-shadow: 0 0 10px 2px var(--hover-shadow);
	}

	@keyframes card-in {
		from {
			opacity: 0;
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.hw-card:hover {
		transform: scale(1.01) translateY(-2px);
		box-shadow: 0 0 18px 4px var(--hover-shadow);
		border-color: #98cbff;
	}

	.hw-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
	}

	.hw-index {
		font-size: 0.75rem;
		color: var(--text-faint);
		letter-spacing: 0.05em;
	}

	.hw-subject {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding: 0.2rem 0.65rem;
		border-radius: 10px;
		border: 1px solid rgba(152, 203, 255, 0.25);
		color: #98cbff;
		background: rgba(152, 203, 255, 0.07);
	}

	:global([data-theme="dark"]) .hw-subject {
		border-color: rgba(152, 203, 255, 0.38);
		color: #98cbff;
		background: rgba(152, 203, 255, 0.15);
	}

	.hw-body {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.hw-title {
		font-size: 1.1rem;
		font-weight: 700;
		line-height: 1.3;
		color: var(--text);
		letter-spacing: -0.01em;
	}

	.hw-desc {
		font-size: 0.9rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin-top: 0.25rem;
	}

	.hw-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		border-top: 1px solid var(--border);
		padding-top: 0.75rem;
		margin-top: auto;
	}

	.hw-year {
		font-size: 0.75rem;
		color: var(--text-faint);
	}

	.hw-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: #98cbff;
		padding: 0.35rem 0.9rem;
		border: 1.5px solid #98cbff;
		border-radius: 10px;
		background: #98cbff10;
		transition:
			background 0.15s,
			color 0.15s,
			box-shadow 0.15s;
		box-shadow: 0 0 5px 1px rgba(152, 203, 255, 0.15);
	}

	.hw-link:hover {
		background: #98cbff;
		color: #fff;
		box-shadow: 0 0 10px rgba(152, 203, 255, 0.45);
	}

	.hw-link-disabled {
		opacity: 0.35;
		cursor: not-allowed;
		pointer-events: none;
	}

	.link-arrow {
		transition: transform 0.15s;
	}

	.hw-link:hover .link-arrow {
		transform: translateX(3px);
	}
</style>
